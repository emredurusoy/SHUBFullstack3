﻿
    @{
        ViewBag.Title = "Session Oku";
    }

    <h2>Session Oku</h2>

    <h3>Session daki kullanıcı adı :</h3>
    <h5>
        Frontend: @Context.Session.GetString("username")
    </h5>
    <h5>
        Backend: @TempData["kullaniciAdi"]
    </h5>

    <hr />

    <h3>Session daki kullanıcı guid :</h3>
    <h5>
        Frontend: @Context.Session.GetString("userguid")
    </h5>
    <h5>
        Backend: @TempData["kullaniciguid"]
    </h5>

    <a href="SessionSil">Session Sil</a>

    <hr />